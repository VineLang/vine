
pub fn main(&io: &IO) {
  let interesting_floats = [
    +0.0,
    -0.0,
    -42.0,
    F32::inf,
    F32::neg_inf,
    F32::nan,
    F32::from_bits(0x0000_0001),
    F32::from_bits(0x0000_0002),
    F32::from_bits(0x0040_0000),
    F32::from_bits(0x007F_FFFF),
    F32::from_bits(0x0080_0000),
    1.0,
    F32::from_bits(0x3F7F_FFFF),
    F32::from_bits(0x3F80_0001),
    F32::from_bits(0x3F7F_FFFE),
    F32::from_bits(0x3F80_0002),
    0.5,
    2.0,
    2.7182817,
    3.1415927,
    F32::from_bits(0x3080_0000),
    F32::from_bits(0x4E80_0000),
    F32::from_bits(0x0100_0000),
    F32::from_bits(0x7EFF_FFFF),
    F32::from_bits(0x7F7F_FFFF),
    1.0e-10,
    1.0e10,
  ];

  for f in interesting_floats {
    io.println("sqrt {f.to_bits()} {f.sqrt().to_bits()}");
    io.println("exp {f.to_bits()} {f.exp().to_bits()}");
    io.println("ln {f.to_bits()} {f.ln().to_bits()}");
    io.println("");
  }
}
