
// @run -d

use #root::rng::Pcg32;

pub fn main(&io: &IO) {
  let i = 0;
  let rng = Pcg32::seeded("Nils made me seed this");
  let list = List::from_fn(
    100_000,
    fn* () {
      i += 1;
      (rng.gen_n32() % 100, i)
    },
  );
  let option_list = list.map(fn* (x) {
    if rng.gen_n32() % 8 == 0 {
      None()
    } else {
      Some(x)
    }
  });

  list.sort[; ord_first]();
  io.println("{list.is_sorted()}");

  option_list.sort();
  io.println("{option_list.show()}");
}

#[manual]
impl ord_first[T, U; Ord[T]]: Ord[(T, U)] {
  fn cmp(&(a: T, _: U), &(b: T, _: U)) -> Ord {
    a.cmp(&b)
  }

  fn le(&(a: T, _: U), &(b: T, _: U)) -> Bool {
    a <= b
  }

  fn lt(&(a: T, _: U), &(b: T, _: U)) -> Bool {
    a < b
  }
}
