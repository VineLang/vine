[
  {
    "send": {
      "jsonrpc": "2.0",
      "id": 1,
      "method": "initialize",
      "params": {
        "capabilities": {},
        "processId": null,
        "rootUri": null
      }
    },
    "recv": {
      "jsonrpc": "2.0",
      "id": 1,
      "result": {
        "capabilities": {
          "definitionProvider": true,
          "documentFormattingProvider": true,
          "documentHighlightProvider": true,
          "documentSymbolProvider": true,
          "hoverProvider": true,
          "positionEncoding": "utf-16",
          "referencesProvider": true,
          "textDocumentSync": 1,
          "workspace": {
            "workspaceFolders": {
              "changeNotifications": true,
              "supported": true
            }
          },
          "workspaceSymbolProvider": true
        }
      }
    }
  },
  {
    "send": {
      "jsonrpc": "2.0",
      "method": "initialized",
      "params": {}
    }
  },
  {
    "wait": {
      "jsonrpc": "2.0",
      "method": "textDocument/publishDiagnostics",
      "params": {
        "diagnostics": [],
        "uri": "file://<root>/prelude.vi"
      }
    }
  },
  {
    "send": {
      "jsonrpc": "2.0",
      "id": 2,
      "method": "textDocument/hover",
      "params": {
        "textDocument": {
          "uri": "file://<root>/root.vi"
        },
        "position": {
          "line": 2,
          "character": 0
        }
      }
    },
    "recv": {
      "jsonrpc": "2.0",
      "id": 2,
      "result": {
        "contents": {
          "kind": "markdown",
          "value": "Vine's standard library.\n"
        },
        "range": {
          "end": {
            "character": 3,
            "line": 2
          },
          "start": {
            "character": 0,
            "line": 2
          }
        }
      }
    }
  }
]
