
use data::Map::Ord;

#[builtin = "Char"]
pub mod Char {
  pub inline_ivy! from_n32: fn(N32) -> Char { fn(x x) }
  pub inline_ivy! as_n32: fn(Char) -> N32 { fn(x x) }

  pub fn cmp(&a: &Char, &b: &Char) -> Ord {
    if a < b {
      Ord::Lt
    } else if a > b {
      Ord::Gt
    } else {
      Ord::Eq
    }
  }

  pub impl to_string: ToString[Char] {
    fn to_string(self: Char) -> String {
      String({ chars: [self] })
    }
  }
}
