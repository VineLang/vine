{
  "name": "ivy",
  "patterns": [
    { "include": "#line-comment" },
    { "include": "#block-comment" },
    { "include": "#path" },
    { "include": "#wire" },
    { "include": "#free" },
    { "include": "#payload" },
    { "include": "#punctuation" }
  ],
  "scopeName": "source.ivy",
  "repository": {
    "line-comment": {
      "match": "//.*",
      "name": "comment.line.double-slash.ivy"
    },
    "block-comment": {
      "begin": "/\\*",
      "end": "\\*/",
      "name": "comment.block.ivy",
      "patterns": [{ "include": "#multi-comment" }]
    },
    "wire": {
      "match": "\\p{ID_Continue}+",
      "name": "variable.ivy"
    },
    "path": {
      "patterns": [
        {
          "match": "\\p{Id_Continue}+:[:\\p{ID_Continue}]*",
          "name": "entity.name.function.ivy"
        },
        {
          "match": ":[:\\p{ID_Continue}]+",
          "name": "string.ivy"
        }
      ]
    },
    "free": {
      "match": "\\^\\w*",
      "name": "variable.language.ivy"
    },
    "payload": {
      "match": "(#)(\\w+)",
      "captures": {
        "1": { "name": "punctuation.ivy" },
        "2": { "name": "constant.numeric.ivy" }
      }
    },
    "punctuation": {
      "match": "[(){}\\[\\],;$=]",
      "name": "punctuation.ivy"
    }
  }
}
